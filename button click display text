<!DOCTYPE html>
<html>
    <head>
        <title>button click display text</title>
        <style>
            #mainbox
            {
               width: 500px;
               height: 500px;
               border: 4px solid rgb(235, 149, 192); 
               padding: 30px;
               text-align: center;
               margin: auto;
               box-shadow: 20px 20px 15px rgb(207, 159, 159);
            } 
            button
            {
                width: 150px;
                height: 50px;
                background-color: rgb(226, 126, 146);
                border: 5px solid palevioletred;
                border-radius: 7px;
                color: white;
            }
            #textbox
            {
                border: 3px solid rgb(221, 217, 208);
                width:250px;
                height: 200px;
                margin-top: 100px;
                margin-left: 120px;
                text-align: center;
                border-radius: 40px;
            } 
        </style>
    </head>
    <body>
        <div id="mainbox">
            <button id="but">click here to start!!</button>
            <div id="textbox"></div>
        </div>

        <script>
            let button=document.getElementById("but");
            let text=document.getElementById("textbox");
            button.onclick=function()
            {
                text.textContent="hello everyone!!";
                text.style.fontSize="50px";
                text.style.color="pink";
            };
        </script>
    </body>
</html>
